# 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warehouse_mvp?schema=public"

# API 基础 URL（前端使用）
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api"

# 应用端口
PORT=3001

# 环境模式：development | production | test
NODE_ENV="development"

# JWT 密钥（必须替换为高强度随机字符串，至少 32 位）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# 日志级别：log | error | warn | debug | verbose
LOG_LEVEL="log"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id        String             @id @default(cuid())
  code      String             @unique
  name      String
  countryCode String?
  cityName  String?
  areaSize  Decimal?           @db.Decimal(12, 2)
  status    String             @default("enabled")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  features  WarehouseFeature[]
  projects  FinanceProject[]
  records   FinanceRecord[]
  demands   Demand[]
  kpiRules  KpiRule[]
  kpiEntries KpiEntry[]
  kpiResults KpiResult[]
  snapshots ProfitSnapshot[]
  partners Partner[]
  users     UserAccount[]
  financeRules FinanceAllocationRule[]
  adjustments FinanceAdjustment[]
  inventoryItems InventoryItem[]
  customers          Customer[]
  bankAccounts       BankAccount[]
}

model UserAccount {
  id          String         @id @default(cuid())
  account     String         @unique
  password    String
  role        String
  phone       String?        @unique
  email       String?
  companyName String?
  warehouseId String?
  status      String         @default("active")
  failedLoginCount Int       @default(0)
  lockedUntil DateTime?
  lastLoginAt DateTime?
  passwordUpdatedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  warehouse    Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  refreshToken RefreshToken?
  requestedAdjustments FinanceAdjustment[] @relation("AdjustmentRequester")
  reviewedAdjustments  FinanceAdjustment[] @relation("AdjustmentReviewer")
  reviewedInventoryItems InventoryItem[]   @relation("InventoryReviewer")
  notifications Notification[]
}

model RefreshToken {
  id         String      @id @default(cuid())
  userId     String      @unique
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WarehouseFeature {
  id         String   @id @default(cuid())
  warehouseId String
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, featureKey])
}

model FinanceProject {
  id          String   @id @default(cuid())
  warehouseId String
  projectCode String?  @unique
  projectName String
  customerName String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  records     FinanceRecord[]
  snapshots   ProfitSnapshot[]
  adjustments FinanceAdjustment[]
  allocationLines FinanceSnapshotAllocationLine[]
  allocationRuleDetails FinanceAllocationRuleDetail[]
}

model FinanceAdjustment {
  id                String   @id @default(cuid())
  warehouseId        String
  projectId          String?
  adjustmentType     String
  amount             Decimal  @db.Decimal(14, 2)
  currencyCode       String   @default("CNY")
  fxRateToCny        Decimal? @db.Decimal(12, 6)
  amountCny          Decimal? @db.Decimal(14, 2)
  reason             String
  status             String   @default("draft")
  requestedByUserId  String
  reviewedByUserId   String?
  reviewNote         String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  warehouse          Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  project            FinanceProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestedBy        UserAccount  @relation("AdjustmentRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy         UserAccount? @relation("AdjustmentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([warehouseId, status, createdAt])
  @@index([projectId, status])
}

model FinanceRecord {
  id          String   @id @default(cuid())
  warehouseId String
  projectId   String?
  recordType  String
  targetModule String?
  moduleData  Json?
  category    String
  amount      Decimal  @db.Decimal(14, 2)
  currencyCode String  @default("CNY")
  fxRateToCny Decimal? @db.Decimal(12, 6)
  amountCny   Decimal? @db.Decimal(14, 2)
  recordDate  DateTime
  counterparty String?
  costNature  String?
  note        String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  project     FinanceProject? @relation(fields: [projectId], references: [id])

  @@index([warehouseId, targetModule, createdAt])
}

model ProfitSnapshot {
  id             String   @id @default(cuid())
  snapshotKey    String   @unique
  warehouseId    String
  projectId      String?
  snapshotType   String
  periodStartDate DateTime
  periodEndDate  DateTime
  totalIncome    Decimal  @db.Decimal(14, 2)
  totalExpense   Decimal  @db.Decimal(14, 2)
  totalPurchaseCost Decimal @db.Decimal(14, 2)
  netProfit      Decimal  @db.Decimal(14, 2)
  status         String   @default("calculated")
  appliedRuleVersionId String?
  appliedSharedExpenseRate Decimal @db.Decimal(8, 4) @default(1)
  appliedPurchaseCostRate Decimal @db.Decimal(8, 4) @default(1)
  appliedAdjustmentAmount Decimal @db.Decimal(14, 2) @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  project        FinanceProject? @relation(fields: [projectId], references: [id])
  partnerResults PartnerProfitResult[]
  appliedRuleVersion FinanceAllocationRuleVersion? @relation(fields: [appliedRuleVersionId], references: [id], onDelete: SetNull)
  allocationLines FinanceSnapshotAllocationLine[]
}

model Partner {
  id          String   @id @default(cuid())
  warehouseId String
  name        String
  ratio       Decimal  @db.Decimal(6, 4)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  results     PartnerProfitResult[]
}

model PartnerProfitResult {
  id           String   @id @default(cuid())
  snapshotId   String
  partnerId    String
  baseProfitAmount Decimal @db.Decimal(14, 2)
  ratioValue   Decimal  @db.Decimal(6, 4)
  adjustmentAmount Decimal @db.Decimal(14, 2) @default(0)
  finalProfitAmount Decimal @db.Decimal(14, 2)
  createdAt    DateTime @default(now())

  snapshot     ProfitSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  partner      Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model FinanceAnalysis {
  id          String   @id @default(cuid())
  warehouseId String?
  analysisType String
  content     String
  riskLevel   String
  createdAt   DateTime @default(now())
}

model ExchangeRate {
  id            String   @id @default(cuid())
  baseCurrency  String
  quoteCurrency String
  rateValue     Decimal  @db.Decimal(12, 6)
  effectiveDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([baseCurrency, quoteCurrency, effectiveDate])
  @@unique([baseCurrency, quoteCurrency, effectiveDate])
}

model FinanceAllocationRule {
  id               String   @id @default(cuid())
  warehouseId       String
  ruleName          String
  scopeType         String
  currentVersionId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  versions          FinanceAllocationRuleVersion[]
}

model FinanceAllocationRuleVersion {
  id                 String   @id @default(cuid())
  ruleId             String
  versionName        String
  effectiveStartAt   DateTime
  isActive           Boolean  @default(false)
  sharedExpenseRate  Decimal  @db.Decimal(8, 4) @default(1)
  purchaseCostRate   Decimal  @db.Decimal(8, 4) @default(1)
  includeAdjustmentsInSnapshot Boolean @default(false)
  createdAt          DateTime @default(now())

  rule               FinanceAllocationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  snapshots          ProfitSnapshot[]
  details            FinanceAllocationRuleDetail[]
}

model FinanceAllocationRuleDetail {
  id             String   @id @default(cuid())
  ruleVersionId  String
  targetType     String
  method         String
  projectId      String?
  ratioValue     Decimal? @db.Decimal(8, 4)
  priority       Int      @default(100)
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())

  ruleVersion    FinanceAllocationRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Cascade)
  project        FinanceProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  allocationLines FinanceSnapshotAllocationLine[]

  @@index([ruleVersionId, targetType, priority, isEnabled])
}

model FinanceSnapshotAllocationLine {
  id                String   @id @default(cuid())
  snapshotId        String
  projectId         String?
  sourceType        String
  method            String
  sourceAmountCny   Decimal  @db.Decimal(14, 2)
  allocatedAmountCny Decimal @db.Decimal(14, 2)
  ratioApplied      Decimal? @db.Decimal(8, 4)
  ruleDetailId      String?
  createdAt         DateTime @default(now())

  snapshot          ProfitSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  project           FinanceProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ruleDetail        FinanceAllocationRuleDetail? @relation(fields: [ruleDetailId], references: [id], onDelete: SetNull)

  @@index([snapshotId, sourceType, createdAt])
}

model KpiRule {
  id              String   @id @default(cuid())
  warehouseId      String
  ruleName         String
  scopeType        String
  currentVersionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  warehouse        Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  versions         KpiRuleVersion[]
}

model KpiRuleVersion {
  id               String   @id @default(cuid())
  ruleId           String
  versionName      String
  effectiveStartAt DateTime
  isActive         Boolean  @default(false)

  businessCeiling  Decimal  @db.Decimal(8, 2) @default(35)
  businessDivisor  Decimal  @db.Decimal(8, 2) @default(10)
  errorCeiling     Decimal  @db.Decimal(8, 2) @default(30)
  errorPenalty     Decimal  @db.Decimal(8, 2) @default(1)
  efficiencyCeiling Decimal @db.Decimal(8, 2) @default(20)
  efficiencyDivisor Decimal @db.Decimal(8, 2) @default(1)
  loadCeiling      Decimal  @db.Decimal(8, 2) @default(15)
  loadMultiplier   Decimal  @db.Decimal(8, 2) @default(10)

  excellentMin     Decimal  @db.Decimal(8, 2) @default(90)
  goodMin          Decimal  @db.Decimal(8, 2) @default(80)
  passMin          Decimal  @db.Decimal(8, 2) @default(70)
  improveMin       Decimal  @db.Decimal(8, 2) @default(60)

  createdAt        DateTime @default(now())

  rule             KpiRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model KpiEntry {
  id           String   @id @default(cuid())
  warehouseId  String
  staffCode    String?
  targetType   String
  cycleType    String
  startDate    DateTime
  endDate      DateTime
  orderCount   Int
  warehouseArea Decimal @db.Decimal(12, 2)
  staffCount   Int
  errorCount   Int
  inboundCount Int
  note         String?
  status       String   @default("submitted")
  createdAt    DateTime @default(now())

  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
}

model KpiResult {
  id           String   @id @default(cuid())
  warehouseId  String
  staffCode    String?
  cycleType    String
  startDate    DateTime
  endDate      DateTime
  totalScore   Decimal  @db.Decimal(8, 2)
  grade        String
  createdAt    DateTime @default(now())

  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  metricScores KpiMetricScore[]
  analysis     KpiAnalysis[]
}

model KpiMetricScore {
  id          String   @id @default(cuid())
  resultId    String
  metricCode  String
  scoreCeiling Decimal @db.Decimal(8, 2)
  actualScore Decimal  @db.Decimal(8, 2)
  createdAt   DateTime @default(now())

  result      KpiResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model KpiAnalysis {
  id         String   @id @default(cuid())
  resultId   String
  analysisType String
  content    String
  riskLevel  String?
  createdAt  DateTime @default(now())

  result     KpiResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model Demand {
  id          String   @id @default(cuid())
  warehouseId String
  demandType  String
  title       String
  description String
  urgency     String
  contactName String?
  wechatId    String?
  intendedQuantity Int?
  status      String   @default("submitted")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  progressLogs DemandProgressLog[]
}

model Product {
  id           String   @id @default(cuid())
  productName  String
  category     String
  coverImageUrl String?
  description  String
  price        Decimal? @db.Decimal(14, 2)
  unit         String?
  stockQuantity Int     @default(0)
  isSellable   Boolean  @default(true)
  status       String   @default("active")
  listedAt     DateTime?
  unlistedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, category, createdAt])
  @@index([status, isSellable, listedAt, unlistedAt])
}

model DemandTypeConfig {
  id          String   @id @default(cuid())
  typeKey     String   @unique
  typeName    String
  description String?
  sortOrder   Int      @default(100)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isEnabled, sortOrder, typeName])
}

model InventoryItem {
  id             String   @id @default(cuid())
  warehouseId    String
  inventoryType  String
  title          String
  description    String
  quantity       Int
  unit           String?
  status         String   @default("draft")
  rejectionReason String?
  reviewedByUserId String?
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  reviewedBy     UserAccount? @relation("InventoryReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([inventoryType, status, createdAt])
  @@index([warehouseId, status, createdAt])
  @@index([reviewedByUserId, reviewedAt])
}

model DemandProgressLog {
  id         String   @id @default(cuid())
  demandId   String
  status     String
  note       String
  createdAt  DateTime @default(now())

  demand     Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String?
  module    String
  moduleId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model OperationLog {
  id         String   @id @default(cuid())
  module     String
  action     String
  operator   String
  payload    String?
  createdAt  DateTime @default(now())

  @@index([module, action, createdAt])
  @@index([operator, createdAt])
  @@index([createdAt])
}

// ============================================================
// 新财务系统模型（暹联海外仓财务逻辑）
// ============================================================

model Customer {
  id                String   @id @default(cuid())
  warehouseId       String
  customerId        String   @unique
  customerName      String
  customerType      String   @default("prepaid")
  currencyPreference String @default("THB")
  exchangeRate      Decimal? @db.Decimal(10, 4)
  contactName       String?
  contactPhone      String?
  wechatId          String?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  rechargeTransactions RechargeTransaction[]
  serviceRevenues      ServiceRevenue[]
  servicePricings      ServicePricing[]

  @@unique([warehouseId, customerId])
  @@index([warehouseId, status])
}

model ChartOfAccounts {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  parentId    String?
  category    String
  level       Int      @default(1)
  isLeaf      Boolean  @default(true)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      ChartOfAccounts?  @relation("AccountTree", fields: [parentId], references: [id])
  children    ChartOfAccounts[] @relation("AccountTree")
  journalEntries JournalEntryLine[]
  bankTransactions BankAccountTransaction[]

  @@index([category, level])
}

model RechargeTransaction {
  id              String   @id @default(cuid())
  customerId      String
  transactionDate DateTime
  type            String
  currency        String
  amountThb       Decimal  @db.Decimal(14, 2)
  amountCny       Decimal  @db.Decimal(14, 2)
  exchangeRate    Decimal? @db.Decimal(10, 4)
  balanceAfterThb Decimal  @db.Decimal(14, 2)
  balanceAfterCny Decimal  @db.Decimal(14, 2)
  remark          String?
  refInvoiceId    String?
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, transactionDate])
  @@index([type, transactionDate])
}

model BankAccount {
  id          String   @id @default(cuid())
  warehouseId String
  accountName String
  accountType String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  transactions BankAccountTransaction[]

  @@index([warehouseId, status])
}

model BankAccountTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  subAccount      String?
  transactionDate DateTime
  month           String
  categoryId      String?
  category        ChartOfAccounts? @relation(fields: [categoryId], references: [id])
  description     String
  incomeThb       Decimal  @db.Decimal(14, 2) @default(0)
  incomeCny       Decimal  @db.Decimal(14, 2) @default(0)
  expenseThb      Decimal  @db.Decimal(14, 2) @default(0)
  expenseCny      Decimal  @db.Decimal(14, 2) @default(0)
  balanceAfterThb Decimal? @db.Decimal(14, 2)
  balanceAfterCny Decimal? @db.Decimal(14, 2)
  remark          String?
  attachments     Json?
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId, transactionDate])
  @@index([month])
}

model ServicePricing {
  id          String   @id @default(cuid())
  customerId  String
  serviceType String
  unitPrice   Decimal  @db.Decimal(14, 4)
  unit        String   @default("THB")
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  isActive    Boolean  @default(true)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, serviceType, effectiveFrom])
}

model ServiceRevenue {
  id              String   @id @default(cuid())
  customerId      String
  serviceMonth    String
  serviceDate     DateTime?
  serviceType     String
  quantity        Decimal  @db.Decimal(14, 2) @default(0)
  unitPrice       Decimal  @db.Decimal(14, 4) @default(0)
  amountThb       Decimal  @db.Decimal(14, 2) @default(0)
  remark          String?
  refOrderId      String?
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, serviceMonth, serviceType, refOrderId])
  @@index([customerId, serviceMonth])
  @@index([serviceMonth])
}

model ConsumableItem {
  id          String   @id @default(cuid())
  warehouseId String
  itemCode    String?
  itemName    String
  category    String   @default("consumable")
  unit        String
  defaultPrice Decimal? @db.Decimal(14, 4)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions ConsumableTransaction[]

  @@index([warehouseId, status])
}

model ConsumableTransaction {
  id              String   @id @default(cuid())
  itemId          String
  transactionDate DateTime
  month           String
  type            String
  quantity        Decimal  @db.Decimal(14, 2)
  unitPrice       Decimal? @db.Decimal(14, 4)
  totalAmount     Decimal? @db.Decimal(14, 2)
  balanceAfter    Decimal  @db.Decimal(14, 2)
  balanceValue    Decimal? @db.Decimal(14, 2)
  remark          String?
  createdAt       DateTime @default(now())

  item            ConsumableItem @relation(fields: [itemId], references: [id])

  @@index([itemId, transactionDate])
  @@index([month])
}

model FixedAsset {
  id              String   @id @default(cuid())
  warehouseId     String
  assetName       String
  assetCode       String?
  nature          String
  purchaseDate    DateTime?
  purchaseQty     Decimal  @db.Decimal(12, 2) @default(0)
  unitPrice       Decimal  @db.Decimal(14, 2) @default(0)
  purchaseAmount  Decimal  @db.Decimal(14, 2) @default(0)
  disposedQty     Decimal  @db.Decimal(12, 2) @default(0)
  balanceQty      Decimal  @db.Decimal(12, 2) @default(0)
  balanceAmount   Decimal  @db.Decimal(14, 2) @default(0)
  depreciationMethod String @default("immediate")
  usefulLife      Int?
  monthlyDepreciation Decimal? @db.Decimal(14, 2)
  accumulatedDepreciation Decimal @db.Decimal(14, 2) @default(0)
  status          String   @default("active")
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([warehouseId, status])
}

model JournalEntry {
  id              String   @id @default(cuid())
  entryNo         String   @unique
  entryDate       DateTime
  month           String
  description     String
  debitTotal      Decimal  @db.Decimal(14, 2)
  creditTotal     Decimal  @db.Decimal(14, 2)
  sourceType      String?
  sourceId        String?
  status          String   @default("posted")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           JournalEntryLine[]

  @@index([month])
  @@index([entryDate])
}

model JournalEntryLine {
  id              String   @id @default(cuid())
  entryId         String
  accountId       String
  debitAmount     Decimal  @db.Decimal(14, 2) @default(0)
  creditAmount    Decimal  @db.Decimal(14, 2) @default(0)
  description     String?

  entry           JournalEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account         ChartOfAccounts @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

model MonthlyProfitLoss {
  id              String   @id @default(cuid())
  warehouseId     String
  month           String
  totalRevenue    Decimal  @db.Decimal(14, 2) @default(0)
  totalCost       Decimal  @db.Decimal(14, 2) @default(0)
  totalFixedAsset Decimal  @db.Decimal(14, 2) @default(0)
  totalExpense    Decimal  @db.Decimal(14, 2) @default(0)
  operatingProfit Decimal  @db.Decimal(14, 2) @default(0)
  netProfit       Decimal  @db.Decimal(14, 2) @default(0)
  revenueDetails  Json?
  expenseDetails  Json?
  calculatedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([warehouseId, month])
  @@index([month])
}

model MonthlyBalanceSheet {
  id              String   @id @default(cuid())
  warehouseId     String
  month           String
  cashAndBank     Decimal  @db.Decimal(14, 2) @default(0)
  otherReceivables Decimal @db.Decimal(14, 2) @default(0)
  inventory       Decimal  @db.Decimal(14, 2) @default(0)
  currentAssets   Decimal  @db.Decimal(14, 2) @default(0)
  fixedAssetsCost Decimal  @db.Decimal(14, 2) @default(0)
  accumulatedDep  Decimal  @db.Decimal(14, 2) @default(0)
  fixedAssetsNet  Decimal  @db.Decimal(14, 2) @default(0)
  totalAssets     Decimal  @db.Decimal(14, 2) @default(0)
  advanceReceived Decimal  @db.Decimal(14, 2) @default(0)
  totalLiabilities Decimal @db.Decimal(14, 2) @default(0)
  paidInCapital   Decimal  @db.Decimal(14, 2) @default(0)
  retainedEarnings Decimal @db.Decimal(14, 2) @default(0)
  totalEquity     Decimal  @db.Decimal(14, 2) @default(0)
  totalLiabAndEquity Decimal @db.Decimal(14, 2) @default(0)
  isBalanced      Boolean  @default(false)
  calculatedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([warehouseId, month])
  @@index([month])
}

model ReconciliationCheck {
  id              String   @id @default(cuid())
  warehouseId     String
  month           String
  checkType       String
  checkName       String
  expectedValue   Decimal  @db.Decimal(14, 2)
  actualValue     Decimal  @db.Decimal(14, 2)
  difference      Decimal  @db.Decimal(14, 2)
  isPassed        Boolean  @default(false)
  details         String?
  checkedAt       DateTime @default(now())

  @@index([warehouseId, month])
}
